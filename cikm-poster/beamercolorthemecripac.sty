% ====================
% TTARAG Poster Color Theme
% ====================

\definecolor{lightgray}{RGB}{245, 246, 250}
\definecolor{blue}{RGB}{0, 105, 180}
\definecolor{darkblue}{RGB}{0, 63, 114}
\definecolor{lightblue}{RGB}{220, 235, 250}
\definecolor{accentblue}{RGB}{41, 128, 185}
\definecolor{blockbg}{RGB}{248, 250, 252}
\definecolor{blockborder}{RGB}{200, 215, 230}

% Basic colors
\setbeamercolor{palette primary}{fg=black,bg=white}
\setbeamercolor{palette secondary}{fg=black,bg=white}
\setbeamercolor{palette tertiary}{bg=black,fg=white}
\setbeamercolor{palette quaternary}{fg=black,bg=white}
\setbeamercolor{structure}{fg=darkblue}

% Headline
\setbeamercolor{headline}{fg=white,bg=darkblue}
\setbeamercolor{headline rule}{bg=accentblue}

% Footline
\setbeamercolor{footline}{fg=white,bg=darkblue}
\setbeamercolor{footline rule}{bg=accentblue}

% Block
\setbeamercolor{block title}{fg=darkblue,bg=white}
\setbeamercolor{block separator}{bg=accentblue}
\setbeamercolor{block body}{fg=black,bg=white}

% Alert Block
\setbeamercolor{block alerted title}{fg=white,bg=accentblue}
\setbeamercolor{block alerted separator}{bg=accentblue}
\setbeamercolor{block alerted body}{fg=black,bg=lightblue}

% Heading
\setbeamercolor{heading}{fg=darkblue}

% Itemize
\setbeamercolor{item}{fg=accentblue}

% Bibliography
\setbeamercolor{bibliography item}{fg=black}
\setbeamercolor{bibliography entry author}{fg=black}
\setbeamercolor{bibliography entry title}{fg=black}
\setbeamercolor{bibliography entry location}{fg=black}
\setbeamercolor{bibliography entry note}{fg=black}
